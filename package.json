{
  "name": "three-convert",
  "version": "0.2.0",
  "description": "Convert JSON-based 3D model representations to three.js geometries and vice versa",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "tsx --test test/**/*.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lowfab/three-convert.git"
  },
  "keywords": [
    "three",
    "mesh",
    "3D-model"
  ],
  "author": "Adrian Sieber",
  "contributors": [
    "Arthur Silber",
    "Stefan Neubert"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Lowfab/three-convert/issues"
  },
  "homepage": "https://github.com/Lowfab/three-convert",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.7.0",
    "@types/three": "^0.184.1",
    "js-yaml": "^4.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "three": "0.184.0"
  }
}
